{

  "paths": {
    "raw_data": "data/raw/Durham",
    "processed_data": "data/processed",
    "combined_filename": "combined_flow_data.csv",
    "cleaned_filename": "cleaned_flow_data.csv",
    "bwf_results_filename":"bwf_results.csv",
    "gwi_removed_filename": "cleaned_gwi.csv",
    "events_filename": "flow_events.csv",
    "event_stats_filename": "event_stats.csv",
    "plots_dir": "results/plots"
  },
  "cleaning": {
    "flow_column": "Flow_MGD",
    "frequency": "15min",
    "interpolation_limit": 4
  },
  "gwi": {
    "fraction_min": 0.85,
    "rolling_window": 30
  },
  "plottting": {
    "plot":"False",
    "figsize": [14, 6],
    "dpi": 300
  },
  "bwf": {
    "k": 2,
    "sigma_method": "robust",
    "max_iterations": 10,
    "threshold": 0.05
  },
  "event": {
    "deviation_threshold": 2,
    "sustain_duration": 3,
    "return_threshold": 0.3,
    "termination_duration": 3,
    "min_inter_event_time": 6,
    "merge_gap_duration": 3,
    "max_internal_gap": 3,
    "min_event_duration": 3,
    "min_peak_excess": 0.1
  },
  "parallel": {
    "n_workers": 15
  }
}
